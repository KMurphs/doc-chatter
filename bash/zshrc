alias aws-cw-query-results="aws logs get-query-results --query-id $(echo '$QUERY_ID')" 
alias aws-cw-query-results-b="aws-cw-query-results --query \"results[*][?field=='@timestamp'||field=='@message']\" --output text" 
# https://gist.github.com/dsmrt/7400867c88e599e8bfc0266a61073f29
aws-cw-query-template() {
    TMP_FILE=/tmp/query
    echo "Typical Steps:"
    echo "  \n"
    echo "  " aws-cw-log-groups
    echo "  \n"
    echo "  " aws-cw-query-start \"/aws/lambda/KumoMercury_EmailProcessor\" \'filter level!=\"debug\" \| limit 1\' \"2023-01-23T08:00:00\" \"2023-01-23T12:00:00\"
    echo "  " aws-cw-query-start \"/aws/lambda/KumoMercury_EmailProcessor\" file://$TMP_FILE \"30 minutes ago\" \"now\"
    echo "Example Query in $TMP_FILE:\n\
fields @timestamp, @message \n\
| sort @timestamp desc"
    echo "  \n"
    echo "  " aws-cw-query-results-b
    echo "  " aws-cw-query-results --query "results[*][?field=='@timestamp'||field=='@message']" --output text
}

aws-cw-query-start() {
    START="${3:-30 minutes ago}"
    END="${4:-now}"
    START_TS=$(date -d $START "+%s")
    END_TS=$(date -d $END "+%s")

    export QUERY_ID=$(aws logs start-query \
    --log-group-name "$1"\
    --start-time "$START_TS" \
    --end-time "$END_TS" \
    --query-string "$2" \
    --query queryId \
    --output text)

    echo "Started query $QUERY_ID between $START($(date -d $START)) and $END($(date -d $END))"
}

